# macOS and editor noise
.DS_Store
.vscode/*.log
.vscode/settings.json

# Python caches and local environments
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/
*.egg-info/
*.ipynb_checkpoints/

# Python general
/python_replication/
*.py
pyproject.toml

# Runtime logs and temporary reports
*.log
*.gph
*.aux
*.toc
*.out
*.lof
*.lot
*.synctex.gz
parity_report.json
parity_report.md
stage_manifest.json
tmp/

# Untracked data skeleton: keep directories, ignore contents
/Reproducibility Package/Data/**
!/Reproducibility Package/Data/.gitkeep
!/Reproducibility Package/Data/CSV/
!/Reproducibility Package/Data/CSV/.gitkeep
!/Reproducibility Package/Data/Excel/
!/Reproducibility Package/Data/Excel/.gitkeep
!/Reproducibility Package/Data/Stata/
!/Reproducibility Package/Data/Stata/.gitkeep

# Generated outputs: keep canonical paper artifacts, ignore scratch space
/Reproducibility Package/Outputs/**
!/Reproducibility Package/Outputs/.gitkeep
!/Reproducibility Package/Outputs/graphs/
!/Reproducibility Package/Outputs/graphs/.gitkeep
!/Reproducibility Package/Outputs/graphs/*.png
!/Reproducibility Package/Outputs/tables/
!/Reproducibility Package/Outputs/tables/.gitkeep
!/Reproducibility Package/Outputs/tables/*.tex
!/Reproducibility Package/Outputs/tables/raw/
!/Reproducibility Package/Outputs/tables/raw/.gitkeep
!/Reproducibility Package/Outputs/StataData_other/
!/Reproducibility Package/Outputs/StataData_other/.gitkeep

# Extension module: keep code, references, paper source, and reviewer-facing artifacts
/Reproducibility Package/Extension/**
!/Reproducibility Package/Extension/
!/Reproducibility Package/Extension/README.md
!/Reproducibility Package/Extension/Reference/
!/Reproducibility Package/Extension/Reference/**
!/Reproducibility Package/Extension/code/
!/Reproducibility Package/Extension/code/*.do
!/Reproducibility Package/Extension/figures/
!/Reproducibility Package/Extension/figures/*.png
!/Reproducibility Package/Extension/figures/*.pdf
!/Reproducibility Package/Extension/tables/
!/Reproducibility Package/Extension/tables/*.tex
!/Reproducibility Package/Extension/paper/
!/Reproducibility Package/Extension/paper/**

# Extension local-only artifacts
/Reproducibility Package/Extension/AGENT_INSTRUCTIONS.md
/Reproducibility Package/Extension/AUDIT_CHECKLIST.md
/Reproducibility Package/Extension/data/**
/Reproducibility Package/Extension/results/raw/**
/Reproducibility Package/Extension/logs/**
/Reproducibility Package/Extension/paper/*.pdf
/Reproducibility Package/Extension/paper/*.aux
/Reproducibility Package/Extension/paper/*.log
/Reproducibility Package/Extension/paper/*.out
/Reproducibility Package/Extension/paper/*.toc
/Reproducibility Package/Extension/paper/*.lof
/Reproducibility Package/Extension/paper/*.lot
/Reproducibility Package/Extension/paper/*.nav
/Reproducibility Package/Extension/paper/*.snm
/Reproducibility Package/Extension/paper/.DS_Store

